{
  "cli": {
    "version": ">= 14.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "googleServicesFile": "./GoogleService-Info.plist"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "googleServicesFile": "./GoogleService-Info.plist"
      },
      "env": {
        "EXPO_PUBLIC_SENTRY_DSN": "@EXPO_PUBLIC_SENTRY_DSN",
        "EXPO_PUBLIC_GMAPS_API_KEY": "@EXPO_PUBLIC_GMAPS_API_KEY"
      },
      "channel": "preview"
    },
    "production": {
      "ios": {
        "googleServicesFile": "./GoogleService-Info.plist"
      },
      "env": {
        "EXPO_PUBLIC_SENTRY_DSN": "@EXPO_PUBLIC_SENTRY_DSN",
        "EXPO_PUBLIC_GMAPS_API_KEY": "@EXPO_PUBLIC_GMAPS_API_KEY"
      },
      "channel": "production"
    }
  }
}